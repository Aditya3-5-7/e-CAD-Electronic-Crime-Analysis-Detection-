<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="90dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:background="#0F172A"
                android:padding="24dp">

                <ImageView
                    android:id="@+id/mainLogo"
                    android:layout_width="93dp"
                    android:layout_height="81dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/logo2" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/mainLogo"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ChallanGuard"
                        android:textColor="#FFFFFF"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Protecting Indian Digital Citizens"
                        android:textColor="#94A3B8"
                        android:textSize="13sp" />
                </LinearLayout>
            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-40dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Link Scam Detector"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#1E293B"
                        app:drawableStartCompat="@android:drawable/ic_menu_share"
                        app:drawableTint="#4338CA"
                        android:drawablePadding="12dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#4338CA">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/urlInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Paste SMS / Website Link"
                            android:textColor="#1E293B"
                            android:inputType="textUri"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <ProgressBar
                        android:id="@+id/scanProgressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:indeterminate="true"
                        android:visibility="gone"
                        android:indeterminateTint="#4338CA"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/CheckLink"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="#4338CA"
                        android:text="CHECK LINK"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        app:elevation="2dp"/>

                    <TextView
                        android:id="@+id/LinkResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:text="Result will appear here"
                        android:textColor="#64748B"
                        android:textSize="15sp"
                        android:background="#F1F5F9"
                        android:padding="12dp"/>

                    <ProgressBar
                        android:id="@+id/riskBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:layout_marginTop="15dp"
                        android:max="100"
                        android:progressTint="#EF4444"
                        android:visibility="invisible"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vehicle Information Hub"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#1E293B"
                        app:drawableStartCompat="@android:drawable/ic_menu_directions"
                        app:drawableTint="#1E293B"
                        android:drawablePadding="12dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeColor="#1E293B">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/VehicleNumber"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Enter Vehicle Number (e.g. MP09XX1234)"
                            android:textColor="#1E293B"
                            android:inputType="textCapCharacters"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/SearchVehicle"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="#1E293B"
                        android:text="SEARCH VEHICLE"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal"
                        android:background="#F8FAFC"
                        android:padding="12dp"
                        android:weightSum="3">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OWNER" android:textSize="11sp" android:textColor="#64748B" android:textStyle="bold"/>
                            <TextView android:id="@+id/QuickOwner" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="--" android:textSize="14sp" android:textColor="#1E293B" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BRAND" android:textSize="11sp" android:textColor="#64748B" android:textStyle="bold"/>
                            <TextView android:id="@+id/QuickCompany" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="--" android:textSize="14sp" android:textColor="#1E293B" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="REG. DATE" android:textSize="11sp" android:textColor="#64748B" android:textStyle="bold"/>
                            <TextView android:id="@+id/QuickDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="--" android:textSize="14sp" android:textColor="#1E293B" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/ViewFineDetailsButton"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:backgroundTint="#EFF6FF"
                            android:text="CHALLANS"
                            android:textStyle="bold"
                            android:textColor="#1D4ED8"
                            app:cornerRadius="8dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/ViewInsuranceButton"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:backgroundTint="#E6F4EA"
                            android:text="INSURANCE"
                            android:textStyle="bold"
                            android:textColor="#137333"
                            app:cornerRadius="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="8dp"
                android:text="Safety Utilities"
                android:textColor="#475569"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:paddingBottom="40dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:id="@+id/actionCheckSMS"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="#FFFFFF"
                    android:layout_marginEnd="8dp"
                    android:padding="16dp"
                    android:elevation="2dp"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:drawable/dialog_holo_light_frame"
                        android:backgroundTint="#F0FDF4"
                        android:padding="12dp"
                        android:src="@android:drawable/sym_action_chat"
                        app:tint="#15803D"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Complain Box"
                        android:textColor="#334155"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionReportFraud"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="#FFFFFF"
                    android:layout_marginStart="8dp"
                    android:padding="16dp"
                    android:elevation="2dp"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@android:drawable/dialog_holo_light_frame"
                        android:backgroundTint="#FEF2F2"
                        android:padding="12dp"
                        android:src="@android:drawable/ic_menu_call"
                        app:tint="#DC2626"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Emergency Help"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#334155"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        app:elevation="16dp"
        app:itemIconTint="#0F172A"
        app:itemTextColor="#0F172A"
        app:menu="@menu/bottom_nav_menu"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>